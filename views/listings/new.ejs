<% layout("/layouts/boilerplate") %>
    <div class="row mt-3">
        <div class="col-8 offset-2">
            <br><br>
    <h3>Create new Listing</h3>
    <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
        <div class="mb-3">
            <label for="title" class="form-label">title</label>
            <input name="listing[title]" placeholder="Add a catchy title" type="text" class="form-control" required>
            <div class="invalid-feedback">Invalid title</div>
        </div>
        <div class="mb-3">
            <label for="description" class="form-label">description</label>
            <textarea name="listing[description]" class="form-control" required></textarea>
            <div class="invalid-feedback">Invalid description</div>
        </div>
        <div class="mb-3">
            <label for="image" class="form-label">Upload image</label>
            <input name="listing[image]" type="file" class="form-control">
        </div>
        <div class="row">
            <div class="mb-3 col-md-4">
                <label for="price" class="form-label">price</label>
                <input name="listing[price]" placeholder="enter price" class="form-control" required>
                <div class="invalid-feedback">Invalid Price</div>
            </div>
            <div class="mb-3 col-md-8">
                <label for="country" class="form-label">country</label>
                <input name="listing[country]" placeholder="enter country" type="text" class="form-control" required>
                <div class="invalid-feedback">Invalid country</div>
            </div>
        </div>
        <div class="mb-3">
            <label for="location" class="form-label">location</label>
            <input name="listing[location]" placeholder="enter location" type="text" class="form-control" required>
            <div class="invalid-feedback">Invalid location</div>
        </div>

        <!-- Category dropdown -->
        <div class="mb-3">
            <label for="category" class="form-label">Category</label>
            <select name="listing[category]" class="form-control" required>
                <option value="">-- Select a category --</option>
                <option value="Trending">🔥 Trending</option>
                <option value="Rooms">🛏️ Rooms</option>
                <option value="Iconic Cities">🏙️ Iconic Cities</option>
                <option value="Mountains">🏔️ Mountains</option>
                <option value="Castles">🏰 Castles</option>
                <option value="Amazing Pools">🏊 Amazing Pools</option>
                <option value="Camping">⛺ Camping</option>
                <option value="Farms">🌾 Farms</option>
                <option value="Arctic">🧊 Arctic</option>
                <option value="Dome">🔮 Dome</option>
                <option value="Cruise">🚢 Cruise</option>
            </select>
            <div class="invalid-feedback">Please select a category</div>
        </div>

        <br> 
        <button class="btn btn-dark add-btn mt-3">ADD</button>
        <br><br><br>
    </form>
    </div>
</div>